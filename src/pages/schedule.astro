---
import Layout from "@/layouts/Layout.astro";
import { ScheduleView } from "@/components/ScheduleView";

const { user } = Astro.locals;
---

<Layout title="Harmonogram">
  <div class="bg-cosmic min-h-screen p-4 md:p-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-white">Harmonogram</h1>
          <p class="text-sm text-blue-100/60">{user?.email}</p>
        </div>
        <a
          href="/dashboard"
          class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-sm text-white transition-colors hover:bg-white/20"
        >
          ← Dashboard
        </a>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-xl md:p-6">
        <ScheduleView client:load />
      </div>
    </div>
  </div>
</Layout>
